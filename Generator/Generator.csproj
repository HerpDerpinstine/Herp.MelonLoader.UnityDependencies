<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <LangVersion>latest</LangVersion>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="Microsoft.AspNetCore.StaticFiles" Version="2.3.11" />
      <PackageReference Include="Octokit" Version="14.0.0" />
    </ItemGroup>
    
    <ItemGroup>
        <None Include="Dependencies/**" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>

    <Target Name="SetExecutablePermissions" AfterTargets="Build">
      <Exec Command="chmod +x &quot;$(OutputPath)Dependencies\7zz&quot;" />
    </Target>

</Project>
